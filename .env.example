# Kardosh monorepo — single env file for Dashboard, Landing, and Welcome
# Copy to .env in this folder (kardosh/.env). Never commit .env.

# ——— Server only (local Vite proxy + Vercel serverless) ———
REELLY_API_KEY=

# ——— Public (VITE_ prefix) ———
VITE_APP_NAME=Kardosh Realty
VITE_CONTACT_EMAIL=info@kardoshrealty.ae
VITE_CONTACT_PHONE=+97141234567
VITE_RERA_LICENSE=1484387
VITE_SOCIAL_LINKEDIN=https://www.linkedin.com/in/allan-kardosh
VITE_SOCIAL_INSTAGRAM=https://www.instagram.com/kardoshrealtydubai


# Public site canonical origin (Landing SEO, sitemap, Open Graph)
VITE_SITE_URL=https://kardoshrealty.ae
# Local dev: http://localhost:5173

# Dashboard: link to public site (local dev / production Landing URL)
VITE_MAIN_SITE_URL=http://localhost:5173

# Landing: redirect admin-only paths (/inquiries, /login, …) to the Dashboard app
# VITE_DASHBOARD_URL=http://localhost:5176
# Vercel preview example: https://kardosh-realty-i3jl.vercel.app

# WhatsApp prefill (Landing + Dashboard inquiry drawer)
# VITE_WHATSAPP_PHONE=97141234567

# Hero — poster stays visible until video plays
# Poster image (bundled 001.webp unless overridden):
VITE_HERO_VIDEO_POSTER=/assets/images/bg/001.webp
# Background video — paste your CDN MP4 URL when ready (no large file in the repo):
# VITE_HERO_VIDEO_URL=https://cdn.example.com/kardosh/dubai-hero.mp4
# Optional: keep using a file in Landing/public/videos/ instead:
# VITE_HERO_VIDEO_URL=/videos/dubai-hero.mp4
# Set true to skip YouTube and wait for VITE_HERO_VIDEO_URL (poster-only until URL is set):
VITE_HERO_USE_LOCAL_VIDEO=true
# VITE_HERO_YOUTUBE_URL=https://youtu.be/YOUR_VIDEO_ID

# Supabase — contact form, admin dashboard, notifications
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional analytics (Landing)
# VITE_GTM_ID=
# VITE_GA_MEASUREMENT_ID=
# VITE_META_PIXEL_ID=

# Welcome / coming-soon app
VITE_LAUNCH_DEADLINE=2026-06-30T00:00:00+04:00
VITE_WELCOME_HEADLINE=We are coming soon
VITE_WELCOME_TAGLINE=Your trusted platform for UAE off-plan and luxury property — launching shortly.
VITE_WELCOME_NOTIFY_EMAIL=allan@kardoshrealty.com
# VITE_WELCOME_URL=
WELCOME_PORT=5180

# Email alerts — copy these into Supabase Edge Function secrets (notify-new-lead), not Vite:
# RESEND_API_KEY=
# RESEND_FROM=Kardosh Realty <kardosh@bookly.my>
# ADMIN_NOTIFY_EMAILS=allan@kardoshrealty.com
# DASHBOARD_URL=http://localhost:5176

{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/videos/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "functions": {
    "api/proxy-image.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.kardoshrealty.ae" }],
      "destination": "https://kardoshrealty.ae/:path*",
      "permanent": true
    }
  ],
  "build": {
    "env": {
      "VITE_HERO_USE_LOCAL_VIDEO": "true",
      "VITE_HERO_VIDEO_URL": "/videos/dubai-hero.mp4"
    }
  },
  "rewrites": [
    {
      "source": "/api/reelly/:path*",
      "destination": "/api/proxy-reelly?path=:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
